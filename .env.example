# ============================================
# WHATSAPP BOT - Environment Variables Template
# ============================================
# Copy file ini ke .env dan isi dengan nilai sebenarnya
# JANGAN commit file .env ke Git!

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3001

# ============================================
# API KEY (SECURITY)
# ============================================
# PENTING: Harus SAMA dengan aplikasi utama
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WA_BOT_API_KEY="your_64_character_api_key_here"

# ============================================
# WEBHOOK URL
# ============================================
# URL Next.js app untuk terima pesan masuk
# Development: http://localhost:3000/api/webhooks/whatsapp
# Production: https://your-app.vercel.app/api/webhooks/whatsapp
NEXTJS_WEBHOOK_URL="http://localhost:3000/api/webhooks/whatsapp"

# ============================================
# DATABASE (PostgreSQL)
# ============================================
# Untuk simpan session WhatsApp
# Gunakan DATABASE_URL yang sama dengan main app
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
